{
  "name": "@benlooper/agent-board-tui",
  "version": "1.0.1",
  "bin": {
    "agent-board-tui": "scripts/cli.ts"
  },
  "files": [
    "scripts/",
    "commands/",
    "AGENT_API.md",
    "dist/server.js",
    "dist/tui.js"
  ],
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "server": "bun run --filter server dev",
    "tui": "bun scripts/tui.ts",
    "build": "bun run --filter '*' build",
    "install:all": "bun install",
    "setup": "bun scripts/setup.ts",
    "build:server": "bun build server/src/index.ts --outfile dist/server.js --target bun",
    "build:tui": "bun scripts/build-tui.ts",
    "prepublishOnly": "bun run build:server && bun run build:tui"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
}
